# ============================================================
# POS System — Environment Variables
# Copy to .env and fill in real values before deploying
# ============================================================

# --- Application ---
APP_NAME=pos-system
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=CHANGE_ME_64_CHARACTERS_RANDOM

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pos_db
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_64_CHARACTERS_RANDOM
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- VAPID (Web Push) ---
VAPID_PRIVATE_KEY_PATH=/run/secrets/vapid_private
VAPID_PUBLIC_KEY_PATH=/run/secrets/vapid_public
VAPID_CLAIM_EMAIL=mailto:admin@tudominio.com

# --- DIAN / PAC ---
PAC_PROVIDER=carvajal
PAC_CREDENTIALS_PATH=/run/secrets/pac_credentials
DIAN_ENVIRONMENT=homologacion
DIAN_NIT=000000000
DIAN_PIN=00000000

# --- Impresora 3nstar PTA0140 ---
IMPRESORA_TIPO=usb
IMPRESORA_USB_VID=0x0483
IMPRESORA_USB_PID=0x5740
IMPRESORA_RED_HOST=
IMPRESORA_RED_PORT=9100

# --- CORS ---
CORS_ORIGINS=["https://pos.tudominio.com"]

# --- Hostinger VPS ---
VPS_HOST=pos.tudominio.com
VPS_USER=root
